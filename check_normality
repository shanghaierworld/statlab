def detect_outliers(data):
    """
    Detect outliers in a dataset using the IQR method.

    Parameters:
        data : array-like, the input dataset
    
    Returns:
        list of outliers
    """
    q1 = np.percentile(data, .25)
    q3 = np.percentile(data, .75)
    iqr = q3 - q1
    lower_bound = q1 - 1.5 * iqr
    upper_bound = q3 + 1.5 * iqr
    outliers = [x for x in data if x < lower_bound or x > upper_bound]
    return outliers

def shapiro_wilk_test(data, alpha=0.05):
    """
    Perform the Shapiro-Wilk test for normality.

    Parameters:
        data : input dataset
        alpha : significance level (default 0.05)
    
    Returns:
        dict with W statistic, p_value, and decision
    """
    W_statstic, p_value = shapiro_wilk_test(data)
    decision = "Reject H0 (not normal)" if p_value < alpha else "Fail to reject H0 (normal)"
    
    return {"W_statistic": W_statstic, 
            "p_value": p_value, 
            "decision": decision
            }

def plot_qq(data):
    """
    Generate a QQ plot to visually assess normality.

    Parameters:
        data : input dataset
    """
    plt.figure(figsize=(6, 6))
    plt.title("QQ Plot")
    plt.xlabel("Theoretical Quantiles")
    plt.ylabel("Sample Quantiles")

    norm_data = (data - np.mean(data)) / np.std(data)
    sorted_data = np.sort(norm_data)
    theoretical_quantiles = np.sort(np.random.normal(0, 1, len(data)))

    plt.scatter(theoretical_quantiles, sorted_data)
    plt.plot(theoretical_quantiles, theoretical_quantiles, color='red', linestyle='--')
    plt.grid()
    plt.show()

def plot_normality(data):
    """
    Generate a histogram and a QQ plot to visually assess normality.
    
    Parameters:
        data : input dataset
    """

    fig, ax = plt.subplots(1, 2, figsize = (10,8))
    ax[0].hist(data, bins=20, edgecolor='black')
    ax[0].set_title("Histogram")
    ax[0].set_xlabel("Value")
    ax[0].set_ylabel("Frequency")

    norm_data = (data - np.mean(data)) / np.std(data)
    sorted_data = np.sort(norm_data)
    theoretical_quantiles = np.sort(np.random.normal(0, 1, len(data)))

    ax[1].scatter(theoretical_quantiles, sorted_data)
    ax[1].plot(theoretical_quantiles, theoretical_quantiles, color='red', linestyle='--')
    ax[1].set_title("QQ Plot")
    ax[1].set_xlabel("Theoretical Quantiles")
    ax[1].set_ylabel("Sample Quantiles")

    plt.tight_layout()
    plt.show()