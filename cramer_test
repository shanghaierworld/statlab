from chi2_independance import chi2_ind 

import numpy as np
import warnings

def cramer_v(observed):

    """
    Calculate Cramér's V statistic as effect size. 
    Magnitude of association between two categorical variables in a contingency table.

    Parameters:
    observed (array-like): A contingency table (2D array) of observed frequencies.

    Outputs:
    float: Cramér's V statistic, ranging from 0 to 1.
    """

    results = chi2_ind(observed)

    chi2_stat = results['chi_squared_statistic']
    n = np.sum(observed)
    r, c = observed.shape
    min_dim = min(r - 1, c - 1)

    cramer_value = np.sqrt(chi2_stat / (n * min_dim))

    if cramer_value < 0 or cramer_value > 1:
        warnings.warn("Cramér's V value is out of bounds (0 to 1). Check the input data and calculations.")
    else:
        if cramer_value < 0.1:
            strength = 'negligible'
        elif cramer_value < 0.3:
            strength = 'weak'
        elif cramer_value < 0.5:
            strength = 'moderate'
        else:            
            strength = 'strong'
        
    results = {
        'p_value': results['p_value'],
        'cramer value': cramer_value,
        'interpretation of strength': strength
    }
    return results